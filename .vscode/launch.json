{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Enron Style Lab",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run_app.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Run Tests",
      "type": "python",
      "request": "launch",
      "module": "unittest",
      "args": ["-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
